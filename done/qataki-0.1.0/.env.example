# QATAKI Configuration
# Copy to .env and adjust values.
# All variables are optional unless marked REQUIRED.

# ── LLM Provider ──────────────────────────────────────────────────────────────
# Options: scan | anthropic | openai | google | ollama | openai_compatible
# "scan" = no LLM, Playwright-based heuristics only (free, no API key needed)
QATAKI_LLM_PROVIDER=scan

# Model name — leave empty to use provider default
# anthropic: claude-sonnet-4-20250514  |  claude-haiku-4-5
# openai:    gpt-4o-mini               |  gpt-4o
# google:    gemini-1.5-flash           |  gemini-1.5-pro
# ollama:    llama3.2                   |  mistral
QATAKI_LLM_MODEL=

# API base URL — required for ollama or openai_compatible
# QATAKI_LLM_API_BASE=http://localhost:11434

# API keys — set the one matching your provider
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GOOGLE_API_KEY=...

# ── Cost Limits (per run) ──────────────────────────────────────────────────────
QATAKI_MAX_LLM_CALLS_PER_RUN=20
QATAKI_MAX_TOKENS_PER_RUN=50000
QATAKI_MAX_STEPS_PER_RUN=25
QATAKI_MAX_CONCURRENT_RUNS=3
QATAKI_RUN_TIMEOUT=300

# Cost limit thresholds (USD)
# QATAKI_MAX_USD_PER_RUN=0.50
# QATAKI_MAX_USD_PER_DAY=5.00
# QATAKI_MAX_USD_PER_MONTH=50.00
# QATAKI_CONFIRM_ABOVE_USD=0.10
# QATAKI_MAX_TOKENS_PER_DAY=500000

# Sparmode: limit token usage when close to budget
# QATAKI_SPARMODE_TOKENS=1024
# QATAKI_SOFT_TOKENS_PER_RUN=30000

# ── Storage ────────────────────────────────────────────────────────────────────
QATAKI_DB_URL=sqlite:///./memory/qataki.sqlite3
QATAKI_ARTIFACTS_DIR=./artifacts
QATAKI_ARTIFACTS_RETENTION=30

# Docker (bind-mount paths inside container)
# QATAKI_DB_URL=sqlite:////data/memory/qataki.sqlite3
# QATAKI_ARTIFACTS_DIR=/data/artifacts

# ── Logging ────────────────────────────────────────────────────────────────────
# Options: DEBUG | INFO | WARNING | ERROR
QATAKI_LOG_LEVEL=INFO

# ── Crawl Settings ─────────────────────────────────────────────────────────────
# Used when mode=crawl (multi-page scan)
QATAKI_MAX_CRAWL_PAGES=20
# QATAKI_CRAWL_MAX_DEPTH=3
# QATAKI_CRAWL_STAY_ON_DOMAIN=true

# ── Credential Vault ───────────────────────────────────────────────────────────
# Encrypted file vault — generate key with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# QATAKI_VAULT_KEY=<base64-fernet-key>

# Optional: custom path for encrypted vault file
# QATAKI_VAULT_FILE=./memory/vault/secrets.enc

# Per-secret env vars (alternative to file vault, always works):
# QATAKI_SECRET_{NAME}=value    e.g. QATAKI_SECRET_LOGIN_EMAIL=user@example.com
# QATAKI_OTP_{NAME}=base32      e.g. QATAKI_OTP_LOGIN_TOTP=JBSWY3DPEHPK3PXP

# ── Notifications ──────────────────────────────────────────────────────────────
# Mattermost incoming webhook URL
# QATAKI_NOTIFY_MATTERMOST=https://mattermost.example.com/hooks/xxx

# Generic POST webhook (receives JSON: {"text": "...", "message": "..."})
# QATAKI_NOTIFY_WEBHOOK=https://hooks.example.com/qataki

# Minimum severity to trigger notification: critical | high | medium | low
# QATAKI_NOTIFY_MIN_SEVERITY=high

# ── Voice Input (Experimental) ─────────────────────────────────────────────────
# Whisper-based voice command interface — requires: pip install voice-input
# Only active when explicitly enabled
# QATAKI_VOICE_ENABLED=false
# QATAKI_VOICE_MODEL=base
# QATAKI_VOICE_LANGUAGE=de
# QATAKI_VOICE_STOP_PHRASE=fertig
